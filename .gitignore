# =============================================================================
# TERRAFORM GITIGNORE
# =============================================================================
# These files must NEVER be committed to git:
#   - .terraform/     = downloaded providers (hundreds of MB, regenerated by init)
#   - *.tfvars        = your actual values (may contain secrets)
#   - *.tfstate       = Terraform state (stored in S3 instead)
#   - *.tfplan        = plan output files (temporary)
# =============================================================================

# Terraform working directories and downloaded providers
**/.terraform/
**/.terraform.lock.hcl

# State files — we use remote state in S3
*.tfstate
*.tfstate.*
*.tfstate.backup

# Variable files containing actual values — these may contain secrets
# The .example files ARE committed so others know the format
terraform.tfvars
*.auto.tfvars
!*.tfvars.example

# Plan files
*.tfplan
*.plan

# Crash logs
crash.log
crash.*.log

# Override files (local customisations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
backend_override.tf

# Terraform CLI config
.terraformrc
terraform.rc

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/settings.json
.idea/
*.swp
*.swo

# Logs
*.log
